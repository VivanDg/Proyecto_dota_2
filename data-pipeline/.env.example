# Supabase (usar la service_role key, no la anon key — este pipeline escribe datos)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# OpenDota (opcional, sube el límite de requests/min)
OPENDOTA_API_KEY=

# Ventana de entrenamiento
MIN_PATCH_NUMBER=7.33
RECENCY_HALF_LIFE_PATCHES=3
